{
  "mcpServers": {
    "padelhub": {
      "command": "node",
      "args": ["e:\\Repositorios\\FRONTEND\\Angular 20\\padelHUB\\mcp-server\\dist\\index.js"],
      "env": {
        "NODE_ENV": "production"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["playwright-mcp"]
    },
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "supercharged-figma-mcp",
        "--local",
        "--relay-host",
        "127.0.0.1",
        "--relay-port",
        "8888"
      ]
    }
  }
}
